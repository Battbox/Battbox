name: Nightly Stream Sync

on:
  schedule:
    - cron: '0 2 * * *'
  workflow_dispatch:

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  sync-streams:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Fetch iptv-org streams API
        run: |
          curl -s --max-time 60 --retry 3 "https://iptv-org.github.io/api/streams.json" -o streams.json
          if [ $(wc -c < streams.json) -lt 10000 ]; then exit 1; fi

      - name: Patch stream URLs into app
        run: |
          python3 << 'PYEOF'
          import json, re, sys, inspect

          code = inspect.cleandoc("""
          import json, re, sys

          ID_MAP = {
              "aljadeed": "AlJadeed.lb", "lbc": "LBCInternational.lb", "mtv-lb": "MTVLebanon.lb",
              "mayadeen": "AlMayadeen.lb", "manar": "AlManar.lb", "aljazeera": "AlJazeera.qa",
              "ajm": "AlJazeeraMubasher.qa", "alarabiya": "AlArabiya.ae", "france24": "France24Arabic.fr",
              "mbc1": "MBC1.sa", "mbc-drama": "MBCDrama.sa", "spacetoon": "Spacetoon.ae",
              "roya": "RoyaTV.jo", "sky-news-ar": "SkyNewsArabia.ae"
          }

          try:
              with open('streams.json', 'r') as f: streams = json.load(f)
              with open('libnan-tv.html', 'r', encoding='utf-8') as f: html = f.read()
          except Exception as e: sys.exit(1)

          api_data = {}
          for s in streams:
              chid, url = s.get('channel'), s.get('url', '')
              if chid and url.lower().endswith('.m3u8') and s.get('status') != 'error':
                  if chid not in api_data: api_data[chid] = []
                  api_data[chid].append(url)

          updated = 0
          for our_id, api_id in ID_MAP.items():
              new_urls = api_data.get(api_id, [])
              if not new_urls: continue
              pattern = r'(id\s*:\s*"' + re.escape(our_id) + r'".*?u\s*:\s*\[)([^\]]*)(\])'
              match = re.search(pattern, html, re.DOTALL)
              if match:
                  existing = re.findall(r'"(https?://[^"]+)"', match.group(2))
                  combined = list(dict.fromkeys(new_urls[:2] + existing))[:4]
                  formatted = ',\n     '.join(f'"{u}"' for u in combined)
                  replacement = f"{match.group(1)}\n     {formatted}\n   {match.group(3)}"
                  html = html[:match.start()] + replacement + html[match.end():]
                  updated += 1

          with open('libnan-tv.html', 'w', encoding='utf-8') as f: f.write(html)
          print(f'Updated {updated} channels')
          """)
          exec(code)
          PYEOF

      - name: Commit and Push
        run: |
          git config user.name "Stream Bot"
          git config user.email "bot@libnan.tv"
          git add libnan-tv.html
          git diff --staged --quiet || (git commit -m "sync streams $(date +'%Y-%m-%d')" && git push)
          
